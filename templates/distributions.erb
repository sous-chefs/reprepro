<% @codenames.each do |dist| -%>
Origin: <%= @fqdn %>
Label: apt repository
Codename: <%= dist %>
Architectures: <%= @architectures.join(" ") %>
Components: <%= @pulls["component"] %>
UDebComponents: <%= @pulls["component"] %>
Description: <%= @description %>
<% if @pgp_email -%>
SignWith: <%= @pgp_email %>
<% end -%>
<%   unless @pulls["name"] == dist -%>
Pull: <%= dist %>
<%   end -%>

<% end -%>
