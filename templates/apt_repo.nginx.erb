#
# Generated by Chef
#

server {
  listen <%= @listen_port %>;
  server_name <%= @fqdn %>;

  access_log /var/log/nginx/apt-access.log;
  error_log /var/log/nginx/apt-error.log;

  location / {
    root <%= @repo_dir %>;
    autoindex  on;
  }

  location ~ /(.*)/conf {
    deny all;
  }

  location ~ /(.*)/db {
    deny all;
  }
}

<% if @ssl -%>
server {
  listen 443 ssl;
  server_name <%= @fqdn %>;

  access_log /var/log/nginx/apt-access.log;
  error_log /var/log/nginx/apt-error.log;

  ssl_certificate <%= @ssl_certificate %>;
  ssl_certificate_key <%= @ssl_certificate_key %>;

  location / {
    root <%= @repo_dir %>;
    autoindex  on;
  }

  location ~ /(.*)/conf {
    deny all;
  }

  location ~ /(.*)/db {
    deny all;
  }
}
<% end -%>
